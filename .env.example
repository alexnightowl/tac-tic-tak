# Root env — consumed by docker-compose.yml via ${VAR} interpolation.
# Copy to .env on the deploy host and fill in real values.

# URL the browser will call the API on. Path must end with /api.
# Same-origin default is /api (the nginx service proxies /api/ → backend).
PUBLIC_API_URL=/api

# Backend secrets.
JWT_SECRET=change-me-please
JWT_EXPIRES_IN=7d
