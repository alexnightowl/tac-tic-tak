generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  nickname       String   @unique
  passwordHash   String
  displayName    String?
  avatarUrl      String?
  bio            String?
  country        String?  // ISO-3166 alpha-2
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Daily-streak tracking. Updated on session finish using the
  // user's local 'YYYY-MM-DD' supplied by the client (no TZ stored
  // server-side — date arithmetic happens on those strings).
  // streakFreezes is auto-applied when the player misses exactly
  // one day; regenerates one week after consumption (see
  // sessions/streak.ts).
  streakDays            Int     @default(0)
  streakFreezes         Int     @default(1)
  streakLastDay         String?
  streakFreezeRegenAt   String?

  // Verified-checkmark flag, surfaced as a small icon next to the
  // nickname everywhere this user is displayed. No frontend admin
  // UI on purpose — flipped manually in the DB for users the
  // operator chooses to recognise.
  verified              Boolean @default(false)

  // Self-attested "I starred the repo" flag. Driven by a button
  // on the achievements page; trust-based since we don't have
  // GitHub OAuth set up.
  starredRepo           Boolean @default(false)

  achievements          UserAchievement[]

  settings       UserSetting?
  progression    UserProgression?
  styleProgressions UserStyleProgression[]
  sessions       TrainingSession[]
  attempts       TrainingAttempt[]
  puzzleHistory  UserPuzzleHistory[]
  reviewItems    ReviewItem[]
  sentFriendRequests     Friendship[] @relation("FriendshipRequester")
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")
}

model UserSetting {
  userId          String  @id
  focusMode       Boolean @default(false)
  accentColor     String  @default("#22c55e")
  boardTheme      String  @default("green")
  pieceSet        String  @default("maestro")
  soundEnabled    Boolean @default(true)
  soundPack       String  @default("wood")
  language        String  @default("en")
  fixedColor      String  @default("auto") // auto | white | black
  animationSpeed  String  @default("normal") // instant | fast | normal | slow
  knightArrow     String  @default("bent")  // bent | straight (right-click arrow shape for knight moves)
  showStreak      Boolean @default(true)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStyleProgression {
  userId              String
  style               String   // bullet | blitz | rapid
  startPuzzleRating   Int      @default(1200)
  currentPuzzleRating Int      @default(1200)
  unlockedStartRating Int      @default(1200)
  // Consecutive sessions started within DEMOTE_PEAK_BAND of the unlock
  // ceiling that failed ≤1 of the 4 criteria. Resets on any non-weak
  // session at peak; ignored entirely for sessions in the comfort zone.
  weakSessionStreak   Int      @default(0)
  // Provisional period: while > 0 the ceiling rides the observed
  // peakRating up freely and snaps down to peakRating when it lands
  // ≥100 below the current ceiling, so a brand-new player finds their
  // real level fast. Decremented per rated session; theme/unrated
  // sessions don't consume it. New rows start at 5; existing rows
  // were backfilled to 0 (already past calibration).
  calibrationSessionsLeft Int  @default(5)
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, style])
}

model UserProgression {
  userId              String @id
  startPuzzleRating   Int    @default(1200)
  currentPuzzleRating Int    @default(1200)
  unlockedStartRating Int    @default(1200)
  updatedAt           DateTime @updatedAt
  user                User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Puzzle {
  id               String  @id
  fen              String
  moves            String
  rating           Int
  ratingDeviation  Int
  popularity       Int
  nbPlays          Int
  gameUrl          String?
  themes           PuzzleTheme[]
  attempts         TrainingAttempt[]
  history          UserPuzzleHistory[]
  reviewItems      ReviewItem[]

  @@index([rating])
  @@index([rating, popularity])
}

model Theme {
  id       Int           @id @default(autoincrement())
  slug     String        @unique
  puzzles  PuzzleTheme[]
}

model PuzzleTheme {
  puzzleId String
  themeId  Int
  puzzle   Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  theme    Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([puzzleId, themeId])
  @@index([themeId])
}

model TrainingSession {
  id              String   @id @default(cuid())
  userId          String
  mode            String   // "mixed" | "theme"
  style           String   @default("blitz") // bullet | blitz | rapid
  theme           String?
  startRating     Int
  durationSec     Int
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  solvedCount     Int      @default(0)
  failedCount     Int      @default(0)
  peakRating      Int      @default(0)
  accuracy        Float    @default(0)
  avgResponseMs   Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts        TrainingAttempt[]

  @@index([userId, startedAt])
  @@index([userId, style, startedAt])
}

model TrainingAttempt {
  id              String   @id @default(cuid())
  sessionId       String
  userId          String
  puzzleId        String
  puzzleRating    Int
  correct         Boolean
  responseMs      Int
  createdAt       DateTime @default(now())
  session         TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle          Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId, createdAt])
}

model UserPuzzleHistory {
  userId     String
  puzzleId   String
  lastSeenAt DateTime @default(now())
  seenCount  Int      @default(1)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle     Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@id([userId, puzzleId])
  @@index([userId, lastSeenAt])
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   // "pending" | "accepted"
  createdAt   DateTime @default(now())
  acceptedAt  DateTime?
  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model UserAchievement {
  userId     String
  // Stable identifier matching one of ACHIEVEMENT_DEFS in
  // apps/backend/src/achievements/registry.ts. Slug is the source
  // of truth — adding/removing an achievement only affects what
  // the registry recognises, never breaks existing rows.
  slug       String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, slug])
  @@index([userId, unlockedAt])
}

model ReviewItem {
  id         String   @id @default(cuid())
  userId     String
  puzzleId   String
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle     Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@unique([userId, puzzleId])
  @@index([userId, resolvedAt])
}
